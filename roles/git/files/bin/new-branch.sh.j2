#!/usr/bin/env bash

set -euo pipefail

USERNAME="{{ work_username }}"

[[ $# -ne 1 ]] && {
    echo "Usage: $0 <ticket-id>"
    exit 1
}

json=$(get-ticket-info.sh "$1" --json)

key=$(echo "${json}" | jq -r '.key')
summary=$(echo "${json}" | jq -r '.fields.summary')
clean_summary=$(echo "${summary}" | sed -E 's/[^a-zA-Z0-9]+/-/g' | sed 's/^-//;s/-$//')
branch="${USERNAME}/${key}-${clean_summary}"

echo "Creating branch: ${branch}"
git checkout master
git pull --ff-only origin master
git switch -c "${branch}"
